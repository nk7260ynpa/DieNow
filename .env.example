# Claude Code CLI 相關設定 (change `migrate-to-claude-cli-subprocess` 之後使用).
# 本專案不再使用 Anthropic API Key; LLM 呼叫改由主機 claude login 建立的
# Claude Max 訂閱 OAuth session 承擔計費.
CLAUDE_CLI_PATH=claude
CLAUDE_CLI_TIMEOUT_SECONDS=30
# 留空代表使用預設 ~/.claude; 若 claude login 存放於他處再填入.
CLAUDE_HOME=

# Project Agent 預設模型; 可填 claude-sonnet-4-*, claude-opus-4-*,
# claude-haiku-4-*; 留空代表走 CLI 預設.
PROJECT_AGENT_MODEL=claude-sonnet-4-7

# structlog 等級.
LOG_LEVEL=INFO
